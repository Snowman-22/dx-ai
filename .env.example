# 필수
OPENAI_API_KEY=sk-...

# 서버
HOST=0.0.0.0
PORT=8000

# ========== DynamoDB (로컬 → 실제 AWS 전환 시 이 블록만 바꾸면 됨) ==========
# 테이블 이름은 로컬/실제 동일하게 써도 됨 (테이블은 환경별로 따로 생성됨).

# ----- 지금: 로컬 DynamoDB (Localstack / DynamoDB Local) -----
DYNAMODB_TABLE_NAME=langgraph-chat-checkpoints
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ----- 나중에: 실제 AWS DynamoDB로 전환 시 -----
# 아래만 사용하고, AWS_ENDPOINT_URL 은 넣지 않음 (설정하지 않으면 실제 AWS 사용).
# DYNAMODB_TABLE_NAME=langgraph-chat-checkpoints
# DYNAMODB_TTL_SECONDS=86400
# AWS_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=실제액세스키
# AWS_SECRET_ACCESS_KEY=실제시크릿키

# ========== Postgres (상품 DB, FastAPI가 직접 조회/벡터검색) ==========
# 로컬
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=snowman
POSTGRES_USER=postgres
POSTGRES_PASSWORD=4245

# 또는 한 줄 URL로 설정(우선 적용)
# DATABASE_URL=postgresql+asyncpg://postgres:4245@localhost:5432/snowman

# ========== 외부 추천 알고리즘 (템플릿 폴더는 수정하지 않음) ==========
# PATH 만 주고 ENTRYPOINT 를 비우면 → pipeline.run_full_pipeline + db.get_engine 경로
# RECOMMENDATION_ALGORITHM_PATH=/data/recommendation_algorithm
# RECOMMENDATION_ALGORITHM_ENTRYPOINT=pipeline:run_full_pipeline
# (커스텀 진입점이면 모듈:함수, 예: main:run_recommendation)
# 추천 템플릿 안에서 추천 *이유 문구*만 LLM 쓰려면 (기본: 끔)
# RECOMMENDATION_PIPELINE_USE_LLM=1
